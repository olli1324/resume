{
  "version": 1,
  "include": ["/*"],
  "exclude": [],
  "routes": [
    {
      "src": "/quizlet/*",
      "dest": "/quizlet/$1"
    },
    {
      "src": "/statistics/*",
      "dest": "/statistics/$1"
    },
    {
      "src": "/statistics",
      "dest": "/statistics/index.html"
    },
    {
      "src": "/CVDL/*",
      "dest": "/CVDL/$1"
    },
    {
      "src": "/CVDL",
      "dest": "/CVDL/index.html"
    },
    {
      "src": "/convopt/*",
      "dest": "/convopt/$1"
    },
    {
      "src": "/convopt",
      "dest": "/convopt/index.html"
    },
    {
      "src": "/nonlinear/*",
      "dest": "/nonlinear/$1"
    },
    {
      "src": "/nonlinear",
      "dest": "/nonlinear/index.html"
    },
    {
      "src": "/etransition/*",
      "dest": "/etransition/$1"
    },
    {
      "src": "/etransition",
      "dest": "/etransition/index.html"
    },
    {
      "src": "/IM/*",
      "dest": "/IM/$1"
    },
    {
      "src": "/IM",
      "dest": "/IM/index.html"
    },
    {
      "src": "/mlia/*",
      "dest": "/mlia/$1"
    },
    {
      "src": "/mlia",
      "dest": "/mlia/index.html"
    },
    {
      "src": "/*",
      "dest": "/index.html"
    }
  ]
}
