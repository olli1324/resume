{
  "version": 1,
  "include": ["/*"],
  "exclude": [],
  "routes": [
    {
      "src": "/quizlet/*",
      "dest": "/quizlet/$1"
    },
    {
      "src": "/statistics/*",
      "dest": "/statistics/$1"
    },
    {
      "src": "/statistics",
      "dest": "/statistics/index.html"
    },
    {
      "src": "/*",
      "dest": "/index.html"
    }
  ]
}
